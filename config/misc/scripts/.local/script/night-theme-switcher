#!/bin/sh
# Sunset/sunrise hook: delegate theming to theme-switch, keep brightness nudge.
#   night-theme-switcher dark|light
set -eu
OPT="${1:-}"

case "$OPT" in
  dark)  "$HOME/.local/script/theme-switch" dark;  bright=30 ;;
  light) "$HOME/.local/script/theme-switch" light; bright=20 ;;
  *) echo "usage: night-theme-switcher dark|light"; exit 64 ;;
esac

# GNOME screen brightness (no-op outside GNOME)
gdbus call --session --dest org.gnome.SettingsDaemon.Power \
  --object-path /org/gnome/SettingsDaemon/Power \
  --method org.freedesktop.DBus.Properties.Set \
  org.gnome.SettingsDaemon.Power.Screen Brightness "<int32 $bright>" >/dev/null 2>&1 || true
