{
  "Main guard": {
    "prefix": "main",
    "body": ["if __name__ == \"__main__\":", "\t$0"]
  },
  "Function": {
    "prefix": "fn",
    "body": ["def $1($2):", "\t$0"]
  },
  "Async function": {
    "prefix": "afn",
    "body": ["async def $1($2):", "\t$0"]
  },
  "Class": {
    "prefix": "cls",
    "body": ["class $1:", "\tdef __init__(self$2):", "\t\t$0"]
  },
  "Dataclass": {
    "prefix": "dcls",
    "body": [
      "@dataclass",
      "class $1:",
      "\t$2: $3",
      "\t$0"
    ]
  },
  "Type hint function": {
    "prefix": "fnt",
    "body": ["def $1($2) -> $3:", "\t$0"]
  },
  "Try/except": {
    "prefix": "tc",
    "body": ["try:", "\t$0", "except $1 as e:", "\t$2"]
  },
  "With": {
    "prefix": "with",
    "body": ["with $1 as $2:", "\t$0"]
  },
  "List comprehension": {
    "prefix": "lc",
    "body": "[$1 for $2 in $3]$0"
  },
  "Dict comprehension": {
    "prefix": "dc",
    "body": "{$1: $2 for $3 in $4}$0"
  },
  "Print": {
    "prefix": "pr",
    "body": "print($0)"
  },
  "F-string": {
    "prefix": "fs",
    "body": "f\"$0\""
  },
  "Pytest test": {
    "prefix": "test",
    "body": ["def test_$1():", "\t$0"]
  },
  "Assert equal": {
    "prefix": "ae",
    "body": "assert $1 == $2, \"$0\""
  }
}
