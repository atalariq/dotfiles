{
  "Main": {
    "prefix": "main",
    "body": [
      "#include <stdio.h>",
      "",
      "int main(int argc, char *argv[]) {",
      "\t$0",
      "\treturn 0;",
      "}"
    ]
  },
  "Main C++": {
    "prefix": "mainpp",
    "body": [
      "#include <iostream>",
      "",
      "int main(int argc, char* argv[]) {",
      "\t$0",
      "\treturn 0;",
      "}"
    ]
  },
  "Include": {
    "prefix": "inc",
    "body": "#include <$0>"
  },
  "Include local": {
    "prefix": "incl",
    "body": "#include \"$0\""
  },
  "Struct": {
    "prefix": "st",
    "body": ["typedef struct {", "\t$0", "} $1;"]
  },
  "Class (C++)": {
    "prefix": "cls",
    "body": [
      "class $1 {",
      "public:",
      "\t$1($2);",
      "\t~$1();",
      "",
      "private:",
      "\t$0",
      "};"
    ]
  },
  "For loop": {
    "prefix": "for",
    "body": ["for (int $1 = 0; $1 < $2; $1++) {", "\t$0", "}"]
  },
  "While": {
    "prefix": "wh",
    "body": ["while ($1) {", "\t$0", "}"]
  },
  "Printf": {
    "prefix": "pf",
    "body": "printf(\"$1\\n\"$0);"
  },
  "Cout": {
    "prefix": "cout",
    "body": "std::cout << $1 << std::endl;"
  },
  "Null check": {
    "prefix": "nc",
    "body": ["if ($1 == NULL) {", "\t$0", "}"]
  },
  "Malloc": {
    "prefix": "mal",
    "body": "$1 *$2 = ($1 *)malloc(sizeof($1) * $3);"
  },
  "Header guard": {
    "prefix": "hg",
    "body": [
      "#ifndef ${1:${TM_FILENAME_BASE/(.*)/${1:/upcase}/}_H}",
      "#define ${1:${TM_FILENAME_BASE/(.*)/${1:/upcase}/}_H}",
      "",
      "$0",
      "",
      "#endif"
    ]
  }
}
