{
  "TODO": {
    "prefix": "todo",
    "body": "TODO: $0"
  },
  "FIXME": {
    "prefix": "fixme",
    "body": "FIXME: $0"
  },
  "NOTE": {
    "prefix": "note",
    "body": "NOTE: $0"
  },
  "Date": {
    "prefix": "date",
    "body": "$CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE"
  },
  "Datetime": {
    "prefix": "dt",
    "body": "$CURRENT_YEAR-$CURRENT_MONTH-${CURRENT_DATE}T$CURRENT_HOUR:$CURRENT_MINUTE:$CURRENT_SECOND"
  }
}
