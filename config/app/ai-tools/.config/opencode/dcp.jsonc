{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",
  "enabled": true,
  "pruneNotification": "minimal",
  "turnProtection": {
    "enabled": true,
    "turns": 6
  },
  "compress": {
    "mode": "range",
    "permission": "allow",
    "showCompression": false,
    "summaryBuffer": true,
    "maxContextLimit": "70%",
    "minContextLimit": "40%",
    "nudgeFrequency": 8,
    "nudgeForce": "strong",
    "protectUserMessages": true
  },
  "strategies": {
    "deduplication": {
      "enabled": true,
      "protectedTools": ["read", "edit", "write"]
    },
    "purgeErrors": {
      "enabled": true,
      "turns": 4,
      "protectedTools": []
    }
  }
}
