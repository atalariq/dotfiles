{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(date)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(diff:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(type:*)",
      "Bash(env)",
      "Bash(printenv:*)",
      "Bash(test:*)",
      "Bash([ *)",
      "Bash(rtk git:*)",
      "Bash(rtk cargo:*)",
      "Bash(rtk go:*)",
      "Bash(rtk pnpm:*)",
      "Bash(rtk npm:*)",
      "Bash(rtk npx:*)",
      "Bash(rtk pytest:*)",
      "Bash(rtk jest:*)",
      "Bash(rtk vitest:*)",
      "Bash(rtk playwright:*)",
      "Bash(rtk tsc:*)",
      "Bash(rtk lint:*)",
      "Bash(rtk prettier:*)",
      "Bash(rtk next:*)",
      "Bash(rtk prisma:*)",
      "Bash(rtk gh:*)",
      "Bash(rtk docker:*)",
      "Bash(rtk kubectl:*)",
      "Bash(rtk ls:*)",
      "Bash(rtk read:*)",
      "Bash(rtk grep:*)",
      "Bash(rtk find:*)",
      "Bash(rtk curl:*)",
      "Bash(rtk wget:*)",
      "Bash(rtk make:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(cargo:*)",
      "Bash(python:*)",
      "Bash(node:*)",
      "Bash(mnemosyne recall:*)",
      "Bash(mnemosyne stats)",
      "Read",
      "Edit",
      "Write",
      "MultiEdit",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~*)",
      "Bash(sudo rm *)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git push --force-with-lease)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(eval *)",
      "Bash(rtk proxy:*)",
      "Bash(rtk rm:*)"
    ],
    "additionalDirectories": [
      "~/Repos"
    ]
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path // empty'); [ -z \"$FILE\" ] && exit 0; EXT=\"${FILE##*.}\"; case \"$EXT\" in ts|tsx|js|jsx|json|css|html|md) command -v prettier &>/dev/null && prettier --write \"$FILE\" 2>/dev/null ;; py) command -v ruff &>/dev/null && ruff format \"$FILE\" 2>/dev/null ;; go) command -v gofmt &>/dev/null && gofmt -w \"$FILE\" 2>/dev/null ;; rs) command -v rustfmt &>/dev/null && rustfmt \"$FILE\" 2>/dev/null ;; rb) command -v rubocop &>/dev/null && rubocop -a \"$FILE\" 2>/dev/null ;; sh|bash) command -v shfmt &>/dev/null && shfmt -w \"$FILE\" 2>/dev/null ;; esac; exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Done — needs input' -t 4000 2>/dev/null; exit 0"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v mnemosyne &>/dev/null && nohup mnemosyne sleep >/dev/null 2>&1 & exit 0"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": false,
    "superpowers@superpowers-dev": true
  },
  "extraKnownMarketplaces": {
    "superpowers-dev": {
      "source": {
        "source": "directory",
        "path": "/home/atalariq/Repos/superpowers"
      }
    }
  },
  "effortLevel": "high",
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "editorMode": "normal",
  "verbose": false
}
