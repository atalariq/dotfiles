{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "theme": "auto",
  "model": "sonnet",
  "effortLevel": "medium",
  "statusLine": {
    "type": "command",
    "command": "bash /home/atalariq/.claude/statusline-command.sh"
  },

  "mcpServers": {
    "mnemosyne": {
      "command": "mnemosyne",
      "args": ["mcp"],
      "env": {}
    },
    "hermes": {
      "command": "hermes",
      "args": ["mcp", "serve"]
    }
  },

  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(date)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(diff *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(type *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(test *)",
      "Bash([ *)",
      "Read",
      "Edit",
      "Write",
      "MultiEdit",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git push --force-with-lease)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(eval *)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path // empty'); [ -z \"$FILE\" ] && exit 0; EXT=\"${FILE##*.}\"; case \"$EXT\" in ts|tsx|js|jsx|json|css|html|md) command -v prettier &>/dev/null && prettier --write \"$FILE\" 2>/dev/null ;; py) command -v ruff &>/dev/null && ruff format \"$FILE\" 2>/dev/null ;; go) command -v gofmt &>/dev/null && gofmt -w \"$FILE\" 2>/dev/null ;; rs) command -v rustfmt &>/dev/null && rustfmt \"$FILE\" 2>/dev/null ;; rb) command -v rubocop &>/dev/null && rubocop -a \"$FILE\" 2>/dev/null ;; sh|bash) command -v shfmt &>/dev/null && shfmt -w \"$FILE\" 2>/dev/null ;; esac; exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Done — needs input' -t 4000 2>/dev/null; exit 0"
          }
        ]
      }
    ]
  }
}
