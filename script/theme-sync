#!/usr/bin/env sh
# theme-sync — regenerate wana themes and vendor them into this repo.
#   theme-sync          # regenerate (runs wana gen.py) and copy per manifest
#   theme-sync --check  # exit 1 if any vendored file is stale (no writes)
# Requires wana checked out (dev-time only). Override its path with WANA_DIR.
set -eu

DOTFILES="$(cd "$(dirname "$0")/.." && pwd)"
WANA="${WANA_DIR:-$HOME/Repos/wana}"
MANIFEST="$DOTFILES/script/theme-manifest"
CHECK=0
[ "${1:-}" = "--check" ] && CHECK=1

[ -d "$WANA" ] || { echo "wana not found at $WANA (set WANA_DIR)"; exit 2; }

if [ "$CHECK" -eq 1 ]; then
  python3 "$WANA/tools/gen.py" --check
else
  python3 "$WANA/tools/gen.py"
fi

# Class C targets (mode=patch): a generated block lives inside an otherwise
# hand-authored file, delimited by "# wana:begin" / "# wana:end" markers
# already present in the dest file. Replaces only what's between them.
patch_merge() {
  # $1 = generated source file, $2 = dest file with markers -> writes $3
  awk -v genfile="$1" '
    BEGIN { found = 0 }
    /^# wana:begin/ { print; while ((getline line < genfile) > 0) print line; skip=1; found=1; next }
    /^# wana:end/   { skip=0; print; next }
    { if (!skip) print }
    END { exit(found ? 0 : 1) }
  ' "$2" > "$3"
}

stale=0
while IFS='|' read -r name src dest _cur _var _reload mode; do
  case "$name" in ''|\#*) continue ;; esac
  for v in dark light; do
    s="$WANA/$(echo "$src"  | sed "s/{v}/$v/g")"
    d="$DOTFILES/$(echo "$dest" | sed "s/{v}/$v/g")"
    [ -f "$s" ] || { echo "MISSING wana output: $s"; exit 3; }
    if [ "$mode" = "patch" ]; then
      tmp="$(mktemp)"
      if ! patch_merge "$s" "$d" "$tmp"; then
        echo "ERROR: no wana:begin/end markers in $d (add them once manually)"
        rm -f "$tmp"; exit 4
      fi
      if [ "$CHECK" -eq 1 ]; then
        if ! cmp -s "$tmp" "$d"; then echo "STALE: $d"; stale=1; fi
        rm -f "$tmp"
      else
        mv "$tmp" "$d"
        echo "vendored $name/$v -> ${d#"$DOTFILES"/}"
      fi
    elif [ "$CHECK" -eq 1 ]; then
      if ! cmp -s "$s" "$d"; then echo "STALE: $d"; stale=1; fi
    else
      mkdir -p "$(dirname "$d")"
      cp "$s" "$d"
      echo "vendored $name/$v -> ${d#"$DOTFILES"/}"
    fi
  done
done < "$MANIFEST"

[ "$CHECK" -eq 1 ] && [ "$stale" -eq 1 ] && { echo "Run: script/theme-sync"; exit 1; }
[ "$CHECK" -eq 1 ] && echo "OK: vendored themes up to date"
exit 0
