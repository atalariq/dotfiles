{
  "unnecessary_code_fade": 0.5,
  "proxy": "",
  "show_edit_predictions": false,
  "edit_predictions": {
    "mode": "subtle"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent": {
    "show_turn_stats": true,
    "use_modifier_to_send": true,
    "play_sound_when_agent_done": "when_hidden",
    "new_thread_location": "new_worktree",
    "single_file_review": true,
    "enable_feedback": false,
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
    "tool_permissions": {
      "default": "allow",
      "tools": {}
    }
  },
  "use_system_window_tabs": false,
  "close_on_file_delete": true,
  "completions": {
    "lsp_insert_mode": "replace"
  },
  "agent_ui_font_size": 16.0,
  "buffer_line_height": "standard",
  "vim_mode": true,
  "auto_update": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "when_closing_with_no_tabs": "platform_default",
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    }
  },
  "buffer_font_family": "Fira Code",
  "buffer_font_size": 14.0,
  "buffer_font_weight": 500.0,
  "context_servers": {
    "icm": {
      "command": "/usr/local/bin/icm",
      "args": [
      "serve"
    ],
      "env": {},
      "settings": {}
    }
  },
  "disable_ai": false,
  "document_folding_ranges": "on",
  "document_symbols": "on",
  "git": {
    "inline_blame": {
      "enabled": false,
      "show_commit_summary": true
    }
  },
  "icon_theme": "Zed (Default)",
  "prettier": {
    "allowed": true
  },
  "project_panel": {
    "dock": "left",
    "hide_gitignore": true,
    "hide_hidden": false,
    "hide_root": false
  },
  "search": {
    "center_on_match": true,
    "regex": true,
    "whole_word": true
  },
  "semantic_tokens": "combined",
  "terminal": {
    "toolbar": {
      "breadcrumbs": true
    }
  },
  "theme": {
    "dark": "Everforest Dark Soft (material)",
    "light": "Gruvbox Light",
    "mode": "system"
  },
  "ui_font_family": "Inter",
  "ui_font_size": 16.0,
  "ui_font_weight": 500.0,
  "use_smartcase_search": true
}