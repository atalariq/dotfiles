// vim: set ft=jsonc:
{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "provider": {
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}",
        "baseURL": "https://openrouter.ai/api/v1"
      }
    }
  },
  "mcp": {
    "brave-search": {
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "BRAVE_API_KEY",
        "docker.io/mcp/brave-search"
      ],
      "enabled": true,
      "type": "local"
    },
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "docling": {
      "command": [
        "uvx",
        "--from=docling-mcp",
        "docling-mcp-server"
      ],
      "enabled": true,
      "type": "local"
    },
    "github": {
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "oauth": false,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "sqz": {
      "type": "local",
      "command": [
        "sqz-mcp",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "typst": {
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "ghcr.io/johannesbrandenburger/typst-mcp:latest"
      ],
      "enabled": true,
      "type": "local"
    },
    "anki": {
      "command": [
        "npx",
        "-y",
        "@ankimcp/anki-mcp-server",
        "--stdio"
      ],
      "enabled": true,
      "environment": {
        "ANKI_CONNECT_URL": "http://localhost:8765"
      },
      "type": "local"
    }
  },
  "plugin": [
    "@mohak34/opencode-notifier@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "@tarquinen/opencode-dcp@latest"
  ]
}
